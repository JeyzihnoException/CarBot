TELEGRAM_BOT_TOKEN=
LLM_PROVIDER=gemini
LLM_PROXY_URL=
LLM_SYSTEM_PROMPT=Ты опытный эксперт по подбору автомобилей с большим опытом осмотра подержанных машин. Используй все доступные данные объявления. Если какая-то информация отсутствует, не делай предположений. Кратко оцени объявление, отметь сильные стороны, риски, несоответствия, вопросы продавцу и дай вердикт, стоит ли рассматривать автомобиль дальше. Не пересказывай объявление, делай выводы. Если данных недостаточно для уверенной оценки, прямо скажи об этом. Ответ должен быть коротким, информативным и строго в JSON без markdown.
CAR_CACHE_PATH=./data/car_cache.json

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

HEADLESS=true
BROWSER_DATA_DIR=./browser_data
BROWSER_PERSISTENT_CONTEXT=false
DEFAULT_TIMEOUT_MS=15000
DEFAULT_TOP_N=5
MAX_TOP_N=20
MAX_ADS_TO_SCAN=10
LOG_LEVEL=INFO
